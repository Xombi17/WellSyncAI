# ===========================================
# WellSync AI — Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# -------------------------------------------
# Database (Supabase Postgres)
# -------------------------------------------
# Use Transaction Pooler URI from Supabase Dashboard → Settings → Database
# Format: postgresql+asyncpg://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql+asyncpg://postgres.your_project_ref:your_password@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# -------------------------------------------
# GitHub Models (Replaces Groq and Ollama)
# -------------------------------------------
GITHUB_TOKEN=github_pat_xxx
GITHUB_CHAT_MODEL=openai/gpt-4o
GITHUB_VISION_MODEL=openai/gpt-4o

# -------------------------------------------
# Voice — Vapi (webhook secret for validation)
# -------------------------------------------
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here
VAPI_API_KEY=your_vapi_api_key
VAPI_ASSISTANT_ID=your_vapi_assistant_id
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id

# -------------------------------------------
# Google Gemini Live API (for Hindi/Marathi voice)
# Get API key from https://aistudio.google.com/app/apikey
# -------------------------------------------
GOOGLE_AI_API_KEY=

# -------------------------------------------
# Sarvam AI (Indian Languages - STT, TTS, Translation)
# Get API key from https://dashboard.sarvam.ai
# -------------------------------------------
SARVAM_API_KEY=

# -------------------------------------------
# App settings
# -------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# -------------------------------------------
# Optional: PostHog analytics (server-side)
# -------------------------------------------
POSTHOG_API_KEY=
