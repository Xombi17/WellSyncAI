# ===========================================
# WellSync AI — Backend Environment Variables
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# -------------------------------------------
# Database (Neon Postgres)
# -------------------------------------------
# Format: postgresql+asyncpg://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx.us-east-2.aws.neon.tech/wellsync?sslmode=require

# -------------------------------------------
# GitHub Models (Replaces Groq and Ollama)
# -------------------------------------------
GITHUB_TOKEN=github_pat_xxx
GITHUB_CHAT_MODEL=openai/gpt-4o
GITHUB_VISION_MODEL=openai/gpt-4o

# -------------------------------------------
# Voice — Vapi (webhook secret for validation)
# -------------------------------------------
VAPI_WEBHOOK_SECRET=your_vapi_webhook_secret_here

# -------------------------------------------
# App settings
# -------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# -------------------------------------------
# Optional: PostHog analytics (server-side)
# -------------------------------------------
POSTHOG_API_KEY=
