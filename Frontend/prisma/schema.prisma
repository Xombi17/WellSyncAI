// Prisma schema - syncs with Backend SQLModel
// Match Backend/app/models/* exactly

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DependentType {
  child
  adult
  elder
  pregnant
}

enum Sex {
  male
  female
  other
}

enum EventCategory {
  vaccination
  checkup
  vitamin
  reminder
}

enum EventStatus {
  upcoming
  due
  overdue
  completed
}

enum ReminderStatus {
  pending
  snoozed
  acknowledged
  completed
}

model Household {
  id               String   @id @default(uuid())
  username         String?   @unique @db.VarChar(50)
  password_hash    String?   @db.VarChar(255)
  auth_id          String?   @unique @map("auth_id") @db.Uuid
  name             String   @map("name") @db.VarChar(200)
  primary_language String  @default("en") @map("primary_language") @db.VarChar(10)
  village_town     String?  @map("village_town") @db.VarChar(200)
  state            String?  @db.VarChar(100)
  district         String?  @db.VarChar(100)
  created_at       DateTime @default(now()) @map("created_at")
  updated_at       DateTime @updatedAt @map("updated_at")

  dependents      Dependent[]
  health_events   HealthEvent[]
  reminders       Reminder[]

  @@map("households")
}

model Dependent {
  id                  String         @id @default(uuid())
  household_id        String         @map("household_id")
  name                String        @db.VarChar(200)
  type                DependentType @map("type")
  date_of_birth       DateTime       @map("date_of_birth") @db.Date
  sex                 Sex          @map("sex")
  expected_delivery_date DateTime?   @map("expected_delivery_date") @db.Date
  notes               String?       @db.VarChar(500)
  created_at          DateTime      @default(now()) @map("created_at")
  updated_at          DateTime      @updatedAt @map("updated_at")

  household          Household    @relation(fields: [household_id], references: [id], onDelete: Cascade)
  health_events     HealthEvent[]
  reminders        Reminder[]

  @@map("dependents")
}

model HealthEvent {
  id                String        @id @default(uuid())
  dependent_id      String        @map("dependent_id")
  household_id      String        @map("household_id")
  name              String        @db.VarChar(300)
  schedule_key      String        @map("schedule_key") @db.VarChar(100)
  category          EventCategory @map("category")
  dose_number       Int?
  due_date          DateTime      @map("due_date") @db.Date
  window_start      DateTime?     @map("window_start") @db.Date
  window_end        DateTime?     @map("window_end") @db.Date
  status            EventStatus  @map("status")
  completed_at     DateTime?     @map("completed_at")
  completed_by     String?       @map("completed_by") @db.VarChar(200)
  location         String?        @map("location") @db.VarChar(200)
  notes             String?        @db.VarChar(500)
  schedule_version String        @map("schedule_version") @db.VarChar(50)
  created_at        DateTime     @default(now()) @map("created_at")
  updated_at        DateTime     @updatedAt @map("updated_at")

  dependent        Dependent    @relation(fields: [dependent_id], references: [id], onDelete: Cascade)
  household        Household    @relation(fields: [household_id], references: [id], onDelete: Cascade)
  reminders        Reminder[]

  @@map("health_events")
}

model Reminder {
  id              String          @id @default(uuid())
  health_event_id String          @map("health_event_id")
  dependent_id   String          @map("dependent_id")
  household_id   String          @map("household_id")
  event_name     String          @db.VarChar(300)
  due_date      DateTime        @map("due_date") @db.Date
  status        ReminderStatus  @map("status")
  snoozed_until  DateTime?       @map("snoozed_until") @db.Date
  created_at    DateTime       @default(now()) @map("created_at")
  updated_at    DateTime       @updatedAt @map("updated_at")

  health_event  HealthEvent   @relation(fields: [health_event_id], references: [id], onDelete: Cascade)
  dependent   Dependent    @relation(fields: [dependent_id], references: [id], onDelete: Cascade)
  household   Household    @relation(fields: [household_id], references: [id], onDelete: Cascade)

  @@map("reminders")
}